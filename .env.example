# Identifiants Supabase (PostgreSQL & Storage)
SUPABASE_DATABASE_URL="postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
SUPABASE_API_URL="https://[PROJECT_ID].supabase.co"
SUPABASE_ANON_KEY="sb_secret_..."

# Clé API IA (optionnelle)
OPENAI_API_KEY="sk-..."
